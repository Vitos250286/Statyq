            <h2 class="text-4xl md:text-6xl font-bold mb-6 text-white drop-shadow-lg">Остановите мгновение.</h2>
            <p class="text-xl text-slate-300 mb-10">Станьте владельцем монументального спокойствия. Установите во дворе, окружите зеленью и наслаждайтесь статусом.</p>
            <button onclick="openModal()" class="bg-gradient-to-r from-lime-400 to-emerald-500 text-slate-950 px-10 py-5 rounded-full text-xl font-bold hover:scale-105 transition-transform shadow-[0_0_40px_rgba(132,204,22,0.5)]">
                Оформить эко-предзаказ за 0₽
            </button>
        </div>
    </section>

    <!-- Подвал -->
    <footer class="bg-[#020617] py-12 border-t border-slate-900 relative z-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center">
            <div class="flex items-center gap-2 mb-4 md:mb-0">
                <i data-lucide="leaf" class="w-5 h-5 text-lime-500"></i>
                <span class="font-bold tracking-widest uppercase text-lime-500">Statiq</span>
            </div>
            <p class="text-slate-500 text-sm">
                &copy; 2026 Statiq Motors. Все права защищены. 100% экологично.
            </p>
        </div>
    </footer>

    <!-- Модальное окно предзаказа -->
    <div id="preorderModal" class="fixed inset-0 z-[100] hidden items-center justify-center px-4">
        <!-- Overlay -->
        <div class="absolute inset-0 bg-[#020617]/80 backdrop-blur-md" onclick="closeModal()"></div>
        
        <!-- Modal Content -->
        <div class="relative glass-panel border border-lime-500/30 p-8 rounded-3xl w-full max-w-md shadow-2xl transform scale-95 transition-transform duration-300 bg-slate-950/80" id="modalContent">
            <button onclick="closeModal()" class="absolute top-4 right-4 text-slate-400 hover:text-white transition-colors">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
            
            <h3 class="text-2xl font-bold mb-2 text-white">Оформление предзаказа</h3>
            <p class="text-slate-400 mb-6 text-sm">Мы свяжемся с вами, чтобы обсудить координаты установки вашего эко-монумента.</p>
            
            <form id="orderForm" onsubmit="submitForm(event)" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Имя</label>
                    <input type="text" required class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-lime-400 transition-colors" placeholder="Грета Тунберг">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Email</label>
                    <input type="email" required class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-lime-400 transition-colors" placeholder="eco@statiq.com">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Где поставим?</label>
                    <select class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-lime-400 transition-colors [&>option]:bg-slate-900">
                        <option>Во дворе (в гармонии с лужайкой)</option>
                        <option>В лесу (как место для медитации)</option>
                        <option>Вместо клумбы на даче</option>
                    </select>
                </div>
                
                <button type="submit" class="w-full bg-gradient-to-r from-lime-400 to-emerald-500 text-slate-950 font-bold py-3 rounded-xl mt-4 hover:opacity-90 transition-opacity shadow-[0_0_20px_rgba(132,204,22,0.3)]">
                    Застолбить место
                </button>
            </form>

            <!-- Сообщение об успехе (скрыто по умолчанию) -->
            <div id="successMessage" class="hidden flex-col items-center justify-center py-8 text-center">
                <div class="w-16 h-16 bg-lime-500/20 text-lime-400 rounded-full flex items-center justify-center mb-4 shadow-[0_0_15px_rgba(132,204,22,0.4)]">
                    <i data-lucide="check" class="w-8 h-8"></i>
                </div>
                <h4 class="text-xl font-bold mb-2 text-white">Отлично! Вы в гармонии.</h4>
                <p class="text-slate-400">Ваша заявка принята. Ожидайте доставки эко-бетонных блоков для фиксации.</p>
                <button onclick="closeModal()" class="mt-6 text-sm text-lime-400 underline hover:text-lime-300">Закрыть</button>
            </div>
        </div>
    </div>

    <script>
        // Инициализация иконок
        lucide.createIcons();

        // Логика параллакса (обновленная для всех элементов на странице)
        document.addEventListener('scroll', () => {
            const scrolled = window.scrollY;
            const parallaxLayers = document.querySelectorAll('.parallax-layer');
            
            parallaxLayers.forEach(layer => {
                const speed = layer.getAttribute('data-speed');
                if (speed) {
                    // Если у элемента есть атрибут data-local, рассчитываем смещение
                    // относительно его секции, чтобы он не улетал за пределы экрана
                    if (layer.hasAttribute('data-local')) {
                        const parent = layer.parentElement;
                        const rect = parent.getBoundingClientRect();
                        // Вычисляем позицию секции относительно центра экрана
                        const centerOffset = (window.innerHeight / 2) - (rect.top + rect.height / 2);
                        layer.style.transform = `translateY(${centerOffset * parseFloat(speed)}px)`;
                    } else {
                        // Классический параллакс для фона главного экрана
                        layer.style.transform = `translateY(${scrolled * parseFloat(speed)}px)`;
                    }
                }
            });
        });

        // Логика модального окна
        const modal = document.getElementById('preorderModal');
        const modalContent = document.getElementById('modalContent');
        const orderForm = document.getElementById('orderForm');
        const successMessage = document.getElementById('successMessage');

        function openModal() {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
        }

        function closeModal() {
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                setTimeout(() => {
                    orderForm.classList.remove('hidden');
                    successMessage.classList.add('hidden');
                    orderForm.reset();
                }, 300);
            }, 200);
        }

        function submitForm(e) {
            e.preventDefault();
            orderForm.classList.add('hidden');
            successMessage.classList.remove('hidden');
            successMessage.classList.add('flex');
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
                closeModal();
            }
        });
    </script>
</body>
</html>
