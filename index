    <style>
        /* Кастомные анимации и стили */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 1s ease-out forwards;
        }
        .delay-100 { animation-delay: 100ms; }
        .delay-200 { animation-delay: 200ms; }
        
        .gradient-text {
            background: linear-gradient(to right, #a3e635, #2dd4bf, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        /* Эффект жидкого стекла */
        .glass-panel {
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(16, 185, 129, 0.15);
            position: relative;
            overflow: hidden;
        }
        
        /* Блик жидкого стекла (анимация) */
        .glass-panel::after {
            content: '';
            position: absolute;
            top: 0; left: -150%; width: 50%; height: 100%;
            background: linear-gradient(to right, rgba(255,255,255,0), rgba(255,255,255,0.08), rgba(255,255,255,0));
            transform: skewX(-25deg);
            animation: glass-shine 7s infinite;
        }
        
        @keyframes glass-shine {
            0% { left: -150%; }
            20% { left: 200%; }
            100% { left: 200%; }
        }

        /* Параллакс слои */
        .parallax-layer {
            position: absolute;
            inset: 0;
            will-change: transform;
        }

        /* Анимация природных элементов (пузыри/жидкость) на фоне */
        .eco-blob {
            position: absolute;
            filter: blur(80px);
            opacity: 0.5;
            animation: float 20s infinite ease-in-out alternate;
            z-index: -1;
        }
        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(8%, 15%) scale(1.1); }
            100% { transform: translate(-8%, 5%) scale(0.9); }
        }

        /* Стили для плавающих элементов параллакса */
        .floating-item {
            position: absolute;
            pointer-events: none;
            z-index: 0;
            opacity: 0.6;
        }
    </style>
